# LLM Wiki — qmd search index (regeneratable)
.qmd/

# Obsidian workspace (local UI state, not content)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Project tooling (local config, not content)
.claude/
.hermes/
IDEA.md

# PLECS sim outputs (regeneratable)
*.csv
data/plecs/templates/PLECS_OUT.csv

# Python bytecode
__pycache__/
*.pyc

# graphify knowledge-graph output (regeneratable via /graphify; ~900MB, mirrors source into obsidian/)
graphify-out/

# Runtime logs & experiment outputs (regeneratable)
results/logs/
experiments/**/logs/
*.log

# Raw data & model weights (read-only raw inputs, large binaries)
data/raw/
*.pt
*.pth
*.onnx
*.safetensors
*.ckpt
*.h5
*.pkl
