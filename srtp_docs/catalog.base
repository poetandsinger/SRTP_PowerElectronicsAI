properties:
  file.name:
    displayName: Note
  type:
    displayName: Type
  field:
    displayName: Field
  status:
    displayName: Status
  evidence:
    displayName: Evidence
  year:
    displayName: Year
  reliability:
    displayName: Reliability
  peer_reviewed:
    displayName: Peer-reviewed
  review_by:
    displayName: Review by
  file.folder:
    displayName: Stage
views:
  - type: table
    name: All notes by field
    groupBy:
      property: field
      direction: ASC
    order:
      - file.name
      - type
      - status
      - evidence
      - file.folder
    sort:
      - property: type
        direction: ASC
  - type: table
    name: By stage
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - field
      - type
      - status
  - type: table
    name: Claims & topics
    filters:
      or:
        - type == "claim"
        - type == "topic"
    order:
      - file.name
      - field
      - status
      - evidence
      - review_by
  - type: table
    name: Sources
    filters:
      and:
        - type == "source"
    order:
      - file.name
      - field
      - year
      - reliability
      - peer_reviewed
