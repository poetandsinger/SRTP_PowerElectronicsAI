      MaskIconRotates on
      MaskDialogCallback "local pwm_config = Dialog:get('Configuration')\n"
"\n"
"if  pwm_config == '1' then -- Sine PWM \n"
"   Dialog:set('svpwm_pattern', 'Visible', false)\n"
"   Dialog:set('fs', 'Visible', true)\n"
"   Dialog:set('m', 'Visible', true)\n"
"   Dialog:set('ph_sine', 'Visible', true)   \n"
"   Dialog:set('ph_sv', 'Visible', false)\n"
"   Dialog:set('ph_hyst', 'Visible', false)\n"
"   Dialog:set('A', 'Visible', false)   \n"
"   Dialog:set('H', 'Visible', false)   \n"
"\n"
"   \n"
"elseif  pwm_config == '2' then -- SV PWM\n"
"   Dialog:set('svpwm_pattern', 'Visible', true)\n"
"   Dialog:set('fs', 'Visible', true)\n"
"   Dialog:set('m', 'Visible', true)\n"
"   Dialog:set('ph_sine', 'Visible', false)   \n"
"   Dialog:set('ph_sv', 'Visible', true)\n"
"   Dialog:set('ph_hyst', 'Visible', false)\n"
"   Dialog:set('A', 'Visible', false)   \n"
"   Dialog:set('H', 'Visible', false)   \n"
"\n"
"elseif pwm_config == '3' then--Hysteresis PWM\n"
"   Dialog:set('svpwm_pattern', 'Visible', false)\n"
"   Dialog:set('A', 'Visible', true)\n"
"   Dialog:set('H', 'Visible', true)   \n"
"   Dialog:set('fs', 'Visible', false)\n"
"   Dialog:set('m', 'Visible', false)\n"
"   Dialog:set('ph_sine', 'Visible', false)   \n"
"   Dialog:set('ph_sv', 'Visible', false)\n"
"   Dialog:set('ph_hyst', 'Visible', true)\n"
"  \n"
"end\n"
