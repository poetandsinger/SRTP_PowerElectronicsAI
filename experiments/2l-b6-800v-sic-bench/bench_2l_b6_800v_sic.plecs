Plecs {
  Name          "bench_2l_b6_800v_sic"
  Version       "4.8"
  CircuitModel  "ContStateSpace"
  StartTime     "0.0"
  TimeSpan      "0.05"
  Timeout       ""
  Solver        "dopri"
  MaxStep       "1e-3"
  InitStep      "-1"
  FixedStep     "1e-3"
  Refine        "10"
  ZCStepSize    "1e-9"
  RelTol        "1e-3"
  AbsTol        "-1"
  TurnOnThreshold "0"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "3"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "2"
  DatatypeOverflowMsg "2"
  DatatypeInheritanceConflictMsg "1"
  ContSampleTimeConflictMsg "1"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "3"
  AssertionAction "1"
  FixedPointDatatypeOverride "1"
  InitializationCommands "% Grid parameters\nVg_rms  = 278;   \t\t\t% Grid vol"
"tage (Vrms)\nVg_peak = Vg_rms*sqrt(2); % Grid voltage (Vpk)\nfac     = 200;\t"
"  \t\t\t% grid frequency (Hz)\n\n% VSI parameters\nPr = 300e3;            \t%"
" Rated power (W)\nZb = Vg_rms^2/Pr;     \t% Base impedance (Ohm)\nLg = 0.1*Zb"
"/(2*pi*fac);\t% Grid connecting reactance (H)\nRg = 0.01*Zb;         \t% Grid"
" connecting resistance (Ohm)\nVdc = 800;             \t% DC voltage (V)\nfs ="
" 16e3; Ta=65; \t\t\t\t\t% Switching frequency (Hz)\nts = 1/fs; \t\t\t\t\t% Sw"
"itching period (s)\n\n% Determining initial conditions\nZinv = Rg + 1i*2*pi*f"
"ac*Lg;% Connecting impedance (Ohm,complex)\nIref = Pr/(3*Vg_rms);      % Refe"
"rence current (Irms)\nVinv = Vg_rms + Iref*Zinv; % VSI generated voltage (Vrm"
"s,complex)\nVinv_rms = abs(Vinv);      % VSI generated voltage magnitude (Vrm"
"s)\nVinv_angle= angle(Vinv);   % VSI generated voltage angle (Rads)\n\nphase_"
"balanced = 2*pi/3*[0 -1 1]; % Ideal balanced three-phase angles (Rads)\n\n% S"
"ine and Space Vector PWM parameters\nVref = Vinv_rms*sqrt(2);  \t% Reference "
"voltage amplitude (V)\nphase_sine  = phase_balanced + Vinv_angle;   % Angles "
"for sine PWM reference (Rads) \nphase_svpwm = phase_balanced + Vinv_angle ..."
"% Angles for space vector PWM reference (Rads)\n                             "
"+ 2*pi*(fac/fs/2); \n\n% Hystersis controller parameters\nIout = Iref*sqrt(2)"
";   \t\t\t% Output current amplitude (A)\nIband_hyst = Iout*0.2; \t\t\t% Hyst"
"ersis current controller deadband (A)\nphase_hyst = phase_balanced; \t% Angle"
"s for hysteresis current reference (Rads)\n\n% Remove complex variables from "
"workspace\nclear('Zinv','Vinv')\n"
  InitialState  "1"
  SystemState   ""
  TaskingMode   "1"
  TaskConfigurations ""
  CodeGenParameterInlining "2"
  CodeGenFloatingPointFormat "2"
  CodeGenAbsTimeUsageMsg "3"
