  InitializationCommands "Load_profile = 1;\nLoad_torque_freq = 0.2;\nTsim = 0.25"
";\nTres = 1e-3;\n% Speed control parameters\n\nT_n = 80.4;\n\n% Torque cont"
"rol parameters\n\n% Control matrix\nZ0 = [0 0 0];\nZ1 = [1 0 0];\nZ2 = [1 1 0"
"];\nZ3 = [0 1 0];\nZ4 = [0 1 1];\nZ5 = [0 0 1];\nZ6 = [1 0 1];\nZ7 = [1 1 1];"
"\n\nTab = [ Z0; Z3; Z7; Z2;\n        Z7; Z4; Z0; Z3;\n        Z0; Z5; Z7; Z4;"
"\n        Z7; Z6; Z0; Z5;\n        Z0; Z1; Z7; Z6;\n        Z7; Z2; Z0; Z1;\n"
"        Z0; Z0; Z0; Z0;\n        Z0; Z0; Z0; Z0; ];\n\nT_n = 80.4;\nPsi_ref ="
" 0.46;\n\ndelta_T = 0.05*T_n;\ndelta_Psi = 0.02*Psi_ref;\n\nRs = 0.1062;\n\n%"
"Circuit parameters\n\nV_n = sqrt(2/3)*220;\nRs = 0.1062;\nRr = 0.0764;\nLls ="
" 0.2145/(2*pi*60);\nLlr = Lls;\nLm = 5.834/(2*pi*60);\nzp = 2;\nJ = 2.8;\nF ="
" 0;\n\n% Initial temperature\nTa = 65;"
